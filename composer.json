{
    "name": "ftl/ponto-ao",
    "description": "SaaS de Assiduidade PontoAO",
    "type": "project",
    "require": {
        "php": "^8.3",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.6",
        "firebase/php-jwt": "^6.10",
        "vlucas/phpdotenv": "^5.6",
        "php-di/php-di": "^7.0",
        "monolog/monolog": "^3.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "process-timeout": 0,
        "allow-plugins": {
            "slim/slim-psr7": true
        },
        "audit": {
            "ignore": [
                "PKSA-y2cr-5h3j-g3ys"
            ]
        }
    }
}
