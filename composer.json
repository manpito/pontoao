{
    "name": "ftl/ponto-ao",
    "description": "SaaS de Assiduidade PontoAO",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "firebase/php-jwt": "^7.0",
        "php-di/php-di": "^7.1",
        "monolog/monolog": "^3.10",
        "dompdf/dompdf": "^2.0",
        "phpoffice/phpspreadsheet": "^2.4",
        "phpmailer/phpmailer": "^6.12",
        "endroid/qr-code": "^5.1",
        "bacon/bacon-qr-code": "^3.1",
        "respect/validation": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "process-timeout": 0,
        "sort-packages": true
